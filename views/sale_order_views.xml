<odoo>
    <record id="view_order_form_inherit_contact_roles_delivery_context" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.contact.roles.delivery.context</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                <attribute name="context">{'default_type': 'delivery', 'default_parent_id': partner_id, 'default_is_company': True, 'contact_roles_force_delivery_company': True}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
